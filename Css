body {
    font-family: Arial;
    background: #f4f4f4;
    text-align: center;
}

.chat-container {
    width: 400px;
    margin: 50px auto;
    background: white;
    padding: 20px;
    border-radius: 10px;
}

#chatbox {
    height: 300px;
    overflow-y: scroll;
    border: 1px solid #ccc;
    margin-bottom: 10px;
    padding: 10px;
}

input {
    width: 70%;
    padding: 10px;
}

button {
    padding: 10px;
}
